# Chatixia Mesh Agent Configuration
name: my-agent

# Registry server URL
registry: "http://localhost:8080"

# LLM provider: azure | ollama | openai
provider: azure
model: gpt-4o

# System prompt (inline). For richer agent profiles, use AGENT.md instead.
# prompt: |
#   You are a helpful assistant.

# Agent profile: place an AGENT.md file alongside this agent.yaml
# to define personality, goals, and constraints in natural language.
# See: https://github.com/Chatixia-AI/chatixia-mesh#agentmd

# Sidecar configuration
# Install: cargo install --git https://github.com/Chatixia-AI/chatixia-mesh chatixia-sidecar
sidecar:
  binary: chatixia-sidecar
  api_key: ak_dev_001
  socket: /tmp/chatixia-sidecar.sock

# Skills to load
skills:
  builtin:
    - calculator
    - delegate
    - list_agents
    - mesh_send
    - mesh_broadcast
    - shell
    - search_knowledge
  dirs: []  # additional skill directories

# Autonomous goals
goals: []
