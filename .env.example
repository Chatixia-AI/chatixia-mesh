# ─── Registry Server ──────────────────────────────────────────────────────
SIGNALING_SECRET=change-me-to-a-random-string
API_KEYS_FILE=api_keys.json

# Optional: TURN relay for NAT traversal
# TURN_URL=turn:your-server:3478
# TURN_SECRET=your-coturn-secret

# ─── Sidecar ─────────────────────────────────────────────────────────────
API_KEY=ak_dev_001
SIGNALING_URL=ws://localhost:8080/ws
TOKEN_URL=http://localhost:8080/api/token
IPC_SOCKET=/tmp/chatixia-sidecar.sock

# ─── Python Agent ────────────────────────────────────────────────────────
CHATIXIA_REGISTRY_URL=http://localhost:8080
CHATIXIA_AGENT_ID=my-agent

# LLM Provider (azure or ollama)
LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-06-01

# Ollama (if LLM_PROVIDER=ollama)
# OLLAMA_URL=http://localhost:11434/v1
# AGENT_MODEL=qwen3:4b

# Logging
RUST_LOG=info
LOG_LEVEL=WARNING
